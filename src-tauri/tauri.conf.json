{
  "productName": "Vox",
  "version": "0.1.0",
  "identifier": "com.vox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vox",
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "width": 420,
        "height": 80,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "externalBin": ["../sidecar/dist/sidecar/sidecar"],
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  }
}
